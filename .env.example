# EnterpriseOps Gym 2 — credentials template.
#
# Copy this to `.env` (which is gitignored), fill in the provider you want, then load it into
# your shell before running:  set -a && . ./.env && set +a
#
# NEVER put real secrets in this file (.env.example is committed). Put them in `.env`.
#
# The gym does NOT auto-load .env — you must source it (the `set -a` line above) so litellm can
# read the keys from the environment. Models are litellm strings, chosen per run with the
# --agent-llm / --user-llm / --judge-llm flags (defaults are gpt-4o / gpt-4o-mini, so for any
# non-OpenAI provider you MUST pass those flags — see the README command variants).

# ── Anthropic (standard API key — recommended for shareable runs) ────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Anthropic OAuth token (Claude Pro/Max/Code) — same variable ──────────────
# litellm auto-detects the `sk-ant-oat` prefix and uses Bearer auth. NOTE: subscription OAuth
# tokens are for interactive use; automated evals may hit usage/rate limits.
# ANTHROPIC_API_KEY=sk-ant-oat01-...

# ── OpenAI ───────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Sarvam (OpenAI-compatible endpoint) ──────────────────────────────────────
# Route via the openai-compatible path: set the base URL and use model ids like
# `openai/sarvam-m`. Confirm the model supports tool/function calling (the agent REQUIRES it).
# OPENAI_API_KEY=<your-sarvam-key>
# OPENAI_BASE_URL=https://api.sarvam.ai/v1

# ── Optional extras ──────────────────────────────────────────────────────────
# LITELLM_DROP_PARAMS=true        # let litellm drop unsupported params for a provider
# AWS_BEARER_TOKEN_BEDROCK=...     # if using bedrock/anthropic.claude-... models
# AWS_REGION=us-east-1
